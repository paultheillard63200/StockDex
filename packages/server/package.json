{
  "name": "@stockdex/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch --env-file=.env index.js",
    "start": "node --env-file=.env index.js",
    "db:seed": "node db/seed.js",
    "db:reset": "node db/seed.js --reset",
    "test": "node --env-file=tests/.env.test --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "socket.io": "^4.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
