# Copier en .env et adapter
PORT=3001
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS — origines autorisées (séparer par virgule)
# 3000 = npx serve (front statique), 5173 = Vite, 8080 = serveurs HTTP usuels
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080

# Tickrate de fluctuation des cours (cron pattern)
# "*/30 * * * * *" = toutes les 30 secondes
MARKET_TICK_CRON=*/30 * * * * *

# Amplitude max d'un tick (en fraction, ex 0.04 = ±4%)
MARKET_TICK_VOLATILITY=0.04
